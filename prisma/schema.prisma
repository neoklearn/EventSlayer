// Prisma schema file for Event Slayer
// Powered by SQLite for active development and easy local setups

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Event {
  id            String   @id @default(uuid())
  title         String
  description   String
  location_name String
  start_date    String   // ISO YYYY-MM-DD
  end_date      String   // ISO YYYY-MM-DD
  time          String   @default("10:00 - 18:00") // Time of the event (e.g. "10:00 - selesai")
  htm           String   @default("Gratis / Belum Tersedia") // Harga Tiket Masuk
  posterUrl     String?  // Path to uploaded image
  cropX         Float    @default(0.0) // Horizontal offset for calendar thumbnail
  cropY         Float    @default(0.0) // Vertical offset for calendar thumbnail
  source_url    String?
  approved      Boolean  @default(false)          // Management panel approval gate
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
